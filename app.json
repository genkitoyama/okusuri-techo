{
  "expo": {
    "name": "okusuri-techo",
    "slug": "okusuri-techo",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "okusuritecho",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.tozangenki.okusuritecho",
      "supportsTablet": true,
      "appleTeamId": "7PFCUSRHKV"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF8F0",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.tozangenki.okusuritecho"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF8F0",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "ワンちゃんや奥さんのプロファイル写真を選ぶために、写真ライブラリへのアクセスを許可してください。",
          "cameraPermission": "ワンちゃんや奥さんのプロファイル写真を撮影するために、カメラへのアクセスを許可してください。"
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "OkusuriSmall",
              "label": "おくすり手帳 (小)",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "description": "今日のお薬サマリー",
              "resizeMode": "horizontal|vertical",
              "widgetFeatures": "reconfigurable"
            },
            {
              "name": "OkusuriMedium",
              "label": "おくすり手帳 (中)",
              "minWidth": "260dp",
              "minHeight": "200dp",
              "description": "今日のお薬リスト",
              "resizeMode": "horizontal|vertical",
              "widgetFeatures": "reconfigurable"
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
